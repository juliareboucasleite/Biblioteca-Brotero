[debug] [2026-04-21T14:34:39.115Z] <<< [apiv2][body] POST https://cloudaicompanion.googleapis.com/v1beta/projects/biblioteca-92b4d/locations/global/instances/default:completeTask {"output":{"messages":[{"content":"Here are four GraphQL operations, including a query and mutations, based on your provided schema, with appropriate authentication and `insecureReason` where applicable:\n\n```graphql\nquery ListAllBooks @auth(level: PUBLIC, insecureReason: \"This operation is safe to expose to the public as it only lists general book information.\") {\n  books {\n    id\n    title\n    author\n    publicationYear\n    summary\n    genres\n    coverImageUrl\n  }\n}\n\nmutation CreateNewUser($username: String!, $email: String!, $displayName: String, $bio: String, $profilePictureUrl: String) @auth(level: PUBLIC, insecureReason: \"This operation allows new users to register.\") {\n  user_insert(data: {\n    username: $username,\n    email: $email,\n    createdAt_expr: \"request.time\",\n    displayName: $displayName,\n    bio: $bio,\n    profilePictureUrl: $profilePictureUrl\n  }) {\n    id\n  }\n}\n\nmutation AddBookToMyList($bookListId: UUID!, $bookId: UUID!, $position: Int!, $note: String) @auth(level: USER, insecureReason: \"This operation is safe to expose to all logged in users as it relates to their own book lists.\") {\n  bookListItem_insert(data: {\n    bookListId: $bookListId,\n    bookId: $bookId,\n    position: $position,\n    addedAt_expr: \"request.time\",\n    note: $note\n  }) {\n    bookListId\n    bookId\n  }\n}\n\nquery GetMyBookLists @auth(level: USER, insecureReason: \"This operation is safe to expose to all logged in users as it retrieves their personal book lists.\") {\n  bookLists(where: { userId: { eq_expr: \"auth.uid\" } }) {\n    id\n    name\n    isPublic\n    description\n    createdAt\n    updatedAt\n    bookListItems {\n      book {\n        title\n        author\n      }\n      position\n      note\n    }\n  }\n}\n```","author":"model"}]},"outputDataContext":{"additionalContext":{"@type":"type.googleapis.com/google.cloud.cloudaicompanion.v1main.ChatOutputDataContext","relatedContent":{}}},"attributionContext":{"citationMetadata":{}}}
